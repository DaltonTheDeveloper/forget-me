# ─────────────────────────────────────────────────────────────
# forget-me environment configuration
# Copy to .env and fill in. NEVER commit your real .env.
# Every key is OPTIONAL for local dev — features degrade cleanly
# when a key is absent (free tier / discovery-only still works).
# ─────────────────────────────────────────────────────────────

# Core ----------------------------------------------------------
# PostgreSQL connection string (required for persistence).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/forgetme

# Public base URL of the API (used by web + cli + email links).
API_BASE_URL=http://localhost:3001

# Secret used to sign email-verification tokens. Generate with:
#   openssl rand -hex 32
VERIFICATION_TOKEN_SECRET=

# Discovery -----------------------------------------------------
# Have I Been Pwned API key (https://haveibeenpwned.com/API/Key).
# Absent => HIBP discovery is skipped, no probing fallback.
HIBP_API_KEY=

# GitHub token to raise public-search rate limits (read-only, no scopes needed).
GITHUB_TOKEN=

# Sending -------------------------------------------------------
# Resend API key for verification + deletion-request emails.
# Absent => sending is disabled (discovery/guides still work).
RESEND_API_KEY=
# From address for outbound mail (must be a verified Resend domain).
RESEND_FROM_EMAIL=privacy@forget-me.dev

# Auth (Clerk) --------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Payments (Stripe) ---------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_LIFETIME=

# Web -----------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
