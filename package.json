{
  "name": "forget-me",
  "version": "0.1.0",
  "private": true,
  "description": "Discover where your email is registered and send real, verification-gated GDPR/CCPA deletion requests — without ever touching your accounts.",
  "license": "MIT",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "db:generate": "bun --cwd packages/api run db:generate",
    "db:migrate": "bun --cwd packages/api run db:migrate",
    "db:seed:guides": "bun --cwd packages/api run db:seed:guides",
    "api:dev": "bun --cwd packages/api run dev",
    "web:dev": "bun --cwd packages/web run dev",
    "web:build": "bun --cwd packages/web run build",
    "cli": "bun --cwd packages/cli run start",
    "typecheck": "bunx tsc --noEmit -p packages/shared && bunx tsc --noEmit -p packages/api",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
